# Handle CORS preflight OPTIONS requests immediately
RewriteEngine On
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Route all api/quotes/ requests through index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/quotes/?$ api/quotes/index.php [QSA,L]
RewriteRule ^api/authors/?$ api/authors/index.php [QSA,L]
RewriteRule ^api/categories/?$ api/categories/index.php [QSA,L]
